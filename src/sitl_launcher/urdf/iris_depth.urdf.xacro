<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="iris">

  <link name="base_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.2 0.2 0.1"/>
      </geometry>
      <material name="dark_grey">
        <color rgba="0.2 0.2 0.2 1"/>
      </material>
    </visual>
  </link>

  <link name="imu_link"/>
  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/>
    <child link="imu_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <xacro:macro name="rotor" params="number origin_xyz">
    <link name="rotor_${number}">
      <visual>
        <geometry>
          <cylinder radius="0.1" length="0.005"/>
        </geometry>
        <material name="prop_color">
          <color rgba="0.5 0.5 0.5 1"/>
        </material>
      </visual>
    </link>
    <joint name="rotor_${number}_joint" type="continuous">
      <parent link="base_link"/>
      <child link="rotor_${number}"/>
      <origin xyz="${origin_xyz}" rpy="0 0 0"/>
      <axis xyz="0 0 1"/>
    </joint>
  </xacro:macro>

  <xacro:rotor number="0" origin_xyz="0.13 -0.22 0.023"/>
  <xacro:rotor number="1" origin_xyz="-0.13 0.2 0.023"/>
  <xacro:rotor number="2" origin_xyz="0.13 0.22 0.023"/>
  <xacro:rotor number="3" origin_xyz="-0.13 -0.2 0.023"/>

  <link name="camera_link">
    <visual>
      <geometry>
        <box size="0.05 0.05 0.05"/>
      </geometry>
      <material name="blue">
        <color rgba="0 0 1 1"/>
      </material>
    </visual>
  </link>

  <joint name="camera_joint" type="fixed">
    <parent link="base_link"/>
    <child link="camera_link"/>
    <origin xyz="0.135 0 0" rpy="0 -0.26 0"/>
  </joint>

<link name="camera_optical_link"/>

<joint name="camera_optical_joint" type="fixed">
  <parent link="camera_link"/>
  <child link="camera_optical_link"/>
  <origin xyz="0 0 0" rpy="0 0.26 0"/>
</joint>

</robot>